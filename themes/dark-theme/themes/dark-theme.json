    "titleBar.inactiveBackground": "#0B0F14",
    "titleBar.inactiveForeground": "#6E7075",

    "statusBar.background": "#0B0F14",
    "statusBar.foreground": "#A7A9AC",
    "statusBar.border": "#151A22",

    "statusBar.noFolderBackground": "#10141B",
