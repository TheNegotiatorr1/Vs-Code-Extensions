    "statusBarItem.hoverBackground": "#141A24",
    "statusBarItem.activeBackground": "#1A1F29",
    "statusBarItem.prominentBackground": "#1A1F29",
    "statusBarItem.prominentForeground": "#A7A9AC",

    "tab.activeBackground": "#10141B",
    "tab.inactiveBackground": "#0B0F14",
    "tab.activeForeground": "#A7A9AC",
    "tab.inactiveForeground": "#6E7075",
    "tab.border": "#151A22",

    "panel.background": "#0B0F14",
    "panel.border": "#151A22",

    "editorGroup.border": "#151A22",
    "editorGroupHeader.tabsBackground": "#0B0F14",

    "list.hoverBackground": "#141A24",
    "list.activeSelectionBackground": "#1F2533",
    "list.inactiveSelectionBackground": "#181D28",

    "scrollbarSlider.background": "#1F2533",
    "scrollbarSlider.hoverBackground": "#2A3040",
    "scrollbarSlider.activeBackground": "#343C50",

    "toolbar.activeBackground": "#141A24",
    "toolbar.hoverBackground": "#10141B",

    "icon.foreground": "#A7A9AC",

    "editorActionList.background": "#10141B",
    "editorActionList.foreground": "#A7A9AC",

    "editorWidget.background": "#10141B",
    "editorWidget.border": "#151A22",

    "editorSuggestWidget.background": "#10141B",
    "editorSuggestWidget.border": "#151A22",
    "editorSuggestWidget.foreground": "#A7A9AC",
    "editorSuggestWidget.selectedBackground": "#1F2533",

    "quickInput.background": "#10141B",
    "quickInput.foreground": "#A7A9AC",
    "quickInputList.focusBackground": "#1F2533",

    "menu.background": "#0B0F14",
    "menu.foreground": "#A7A9AC",
    "menu.selectionBackground": "#141A24",
    "menu.selectionForeground": "#FFFFFF",
    "menu.separatorBackground": "#151A22",

    "menubar.selectionBackground": "#141A24",
    "menubar.selectionForeground": "#A7A9AC",
    "menubar.selectionBorder": "#A7A9AC"
