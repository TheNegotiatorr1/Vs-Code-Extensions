{
  "name": "Dark Theme",
  "colors": {
    "focusBorder": "#2306e2",

    "editor.background": "#0B0F14",
    "editor.foreground": "#A7A9AC",

    "editorCursor.foreground": "#702c2c",
    "editor.selectionBackground": "#702c2c",
    "editor.inactiveSelectionBackground": "#0000",
    "editor.lineHighlightBackground": "#10141B",

    "editorLineNumber.foreground": "#4A4F5A",
    "editorLineNumber.activeForeground": "#A7A9AC",

    "activityBar.background": "#0B0F14",
    "activityBar.foreground": "#A7A9AC",
    "activityBar.inactiveForeground": "#6E7075",

    "sideBar.background": "#0B0F14",
    "sideBar.foreground": "#A7A9AC",
    "sideBar.border": "#151A22",

    "sideBarTitle.foreground": "#A7A9AC",
    "sideBarSectionHeader.foreground": "#A7A9AC",
